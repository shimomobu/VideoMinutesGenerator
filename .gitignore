# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# 仮想環境
.venv/
venv/
env/

# テスト・カバレッジ
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# 型チェック
.mypy_cache/

# 環境変数・機密情報
.env
.env.local

# データディレクトリ（入力動画・中間データ・出力）
data/input/*
data/work/*
data/output/*
logs/*

# データディレクトリ自体は管理対象（.gitkeep で保持）
!data/input/.gitkeep
!data/work/.gitkeep
!data/output/.gitkeep
!logs/.gitkeep

# テスト用フィクスチャ動画（バイナリは除外）
tests/fixtures/*.mp4
tests/fixtures/*.mov
tests/fixtures/*.mkv
tests/fixtures/*.wav

# 評価用実データ動画（個人情報・機密情報を含む可能性があるためリポジトリ外管理）
eval/samples/**/*.mp4
eval/samples/**/*.mov
eval/samples/**/*.mkv
eval/samples/**/*.wav

# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.swp
*.swo
